# ====================================================================
# SENSITIVE DATA & ENVIRONMENT VARIABLES
# ====================================================================
# Block private keys, credentials, and local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.cert


# ====================================================================
# DEPENDENCIES & PACKAGE MANAGERS
# ====================================================================
# Node.js
node_modules/
jspm_packages/

# Python Virtual Environments
.venv/
venv/
ENV/
env/

# Ruby & PHP
.bundle/
vendor/


# ====================================================================
# BUILD OUTPUTS, LOGS, & CACHES
# ====================================================================
# Build & distribution directories
dist/
build/
out/
.next/
.nuxt/

# Logs and runtime data
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# Testing tool caches
.coverage
coverage/
.jest/


# ====================================================================
# IDE, EDITORS, & TOOLS
# ====================================================================
# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json

# JetBrains (WebStorm, IntelliJ, PhpStorm, PyCharm, etc.)
.idea/

# General editor files
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp


# ====================================================================
